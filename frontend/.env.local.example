# WebSocket URL for the Orqis backend
# Local dev:
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
# Railway/production:
# NEXT_PUBLIC_WS_URL=wss://your-orqis.up.railway.app/ws

# REST API URL for fetching incidents/events
NEXT_PUBLIC_API_URL=http://localhost:8000
# Railway/production:
# NEXT_PUBLIC_API_URL=https://your-orqis.up.railway.app
