# LLM provider: "ollama" (free, local) or "anthropic" (paid)
LLM_PROVIDER=ollama

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_key_here

# Ollama settings (only used when LLM_PROVIDER=ollama)
# Install: brew install ollama && ollama serve && ollama pull llama3.2:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Redis (Railway Redis plugin sets this automatically on deploy)
REDIS_URL=redis://localhost:6379

# URL of this Orqis backend (used by the local daemon to POST events)
ORQIS_BACKEND_URL=http://localhost:8000

# Auth token for the /drain endpoint.
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave blank for local dev. Always set this in production.
ORQIS_DRAIN_TOKEN=
