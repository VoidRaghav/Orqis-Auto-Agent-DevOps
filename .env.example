# Orqis backend configuration. Copy to .env and fill in.
# Everything has a safe local-dev default; only set what you need.

# --- LLM provider -------------------------------------------------------------
# "ollama" (free, local) or "anthropic" (paid).
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Core infra ---------------------------------------------------------------
REDIS_URL=redis://localhost:6379
ORQIS_BACKEND_URL=http://localhost:8000

# RCA source root for local-dev traceback resolution (server uses GitHub instead).
ORQIS_PROJECT_ROOT=

# Dashboard origins allowed to call the API (comma-separated; first is used for
# the post-install redirect). Add your Vercel URL in production.
ORQIS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Ingest / integration auth ------------------------------------------------
# Long random string protecting the public /drain endpoint. Empty = open (dev only).
ORQIS_DRAIN_TOKEN=
# Sentry internal-integration Client Secret (webhook signature verification).
ORQIS_SENTRY_SECRET=

# --- GitHub App (PR-first auto-fix) -------------------------------------------
# Create at GitHub -> Settings -> Developer settings -> GitHub Apps.
# Permissions: Contents (read/write), Pull requests (write), Metadata (read).
# Subscribe to events: installation, installation_repositories, pull_request.
# Webhook URL: https://<your-backend>/integrations/github/webhook
# Setup URL (post-install redirect): https://<your-backend>/integrations/github/callback
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Provide the PEM key inline (use \n for newlines) OR point to a file path.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# Public base URL of this backend (webhook + redirect links).
ORQIS_PUBLIC_URL=http://localhost:8000

# --- Security -----------------------------------------------------------------
# REQUIRED for dogfood and production. Write endpoints (approve, dismiss, open-pr,
# resolve, PUT /settings) return 401 when unset. Generate with:
#   openssl rand -hex 32
# Use the same value in the dashboard Settings page, MCP env (see .mcp.json), or:
#   orqis mcp --admin-token <token>
ORQIS_ADMIN_TOKEN=
# Set ORQIS_CI=1 in harness/CI; blocks ?force=true on approve unless ORQIS_ALLOW_FORCE=1.
ORQIS_CI=
ORQIS_ALLOW_FORCE=
# Set to 0 in production to require webhook secrets and reject unsigned callbacks.
ORQIS_DEV_MODE=1
# Enable per-workspace isolation + GitHub OAuth login (production hosted).
ORQIS_MULTI_TENANT=0
# Disable local-disk patch apply (PR-only) on hosted deployments.
ORQIS_HOSTED=0
# When ORQIS_HOSTED=1 + ORQIS_MULTI_TENANT=1: do NOT set ORQIS_ADMIN_TOKEN (session auth only).
# Sentry webhooks in multi-tenant mode require Authorization: Bearer <workspace ingest key>.
# HMAC secret for session cookies and install-state signing (generate: openssl rand -hex 32)
ORQIS_SESSION_SECRET=
ORQIS_SESSION_SECURE=0
# GitHub OAuth App (login) — separate from the GitHub App above (PR automation).
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Per-workspace ingest rate limit (requests/min). 0 = unlimited.
ORQIS_INGEST_RATE_LIMIT=600
# HMAC secret for signing outbound hot-reload callbacks. Your app verifies it.
ORQIS_RELOAD_SECRET=
